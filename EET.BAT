@ECHO OFF
REM EssentialEnterpriseThingy DOS command batcher

IF "%1"=="" GOTO HELP

:PARSE
IF "%1"=="" GOTO DONE

IF "%1"=="/MAP" GOTO MAP
IF "%1"=="/DEFRAG" GOTO DO_DEFRAG
IF "%1"=="/TCPIP" GOTO DO_TCPIP
IF "%1"=="/ALL" GOTO DO_ALL
IF "%1"=="/?" GOTO HELP

ECHO Unknown option: %1
GOTO HELP_ERR

:MAP
IF "%2"=="" GOTO MAP_ERR
IF "%3"=="" GOTO MAP_ERR
ECHO Mapping drive %2 to %3...
NET USE %2 %3
IF ERRORLEVEL 1 GOTO FAIL
SHIFT
SHIFT
SHIFT
GOTO PARSE

:DO_DEFRAG
IF "%2"=="" GOTO DEFRAG_ERR
ECHO Defragmenting %2...
DEFRAG %2 /F
IF ERRORLEVEL 1 GOTO FAIL
SHIFT
SHIFT
GOTO PARSE

:DO_TCPIP
IF "%2"=="" GOTO TCP_ERR
ECHO Checking TCP/IP connectivity to %2...
IF EXIST \MTCP\PING.EXE \MTCP\PING %2
IF NOT EXIST \MTCP\PING.EXE PING %2
IF ERRORLEVEL 1 GOTO FAIL
SHIFT
SHIFT
GOTO PARSE

:DO_ALL
IF "%MAP_DRIVE%"=="" GOTO ALL_ERR
IF "%SHARE_PATH%"=="" GOTO ALL_ERR
IF "%DEFRAG_DRIVE%"=="" GOTO ALL_ERR
IF "%TCP_HOST%"=="" GOTO ALL_ERR

ECHO Running full batch (/ALL)...
ECHO Mapping drive %MAP_DRIVE% to %SHARE_PATH%...
NET USE %MAP_DRIVE% %SHARE_PATH%
IF ERRORLEVEL 1 GOTO FAIL

ECHO Defragmenting %DEFRAG_DRIVE%...
DEFRAG %DEFRAG_DRIVE% /F
IF ERRORLEVEL 1 GOTO FAIL

ECHO Checking TCP/IP connectivity to %TCP_HOST%...
IF EXIST \MTCP\PING.EXE \MTCP\PING %TCP_HOST%
IF NOT EXIST \MTCP\PING.EXE PING %TCP_HOST%
IF ERRORLEVEL 1 GOTO FAIL

SHIFT
GOTO PARSE

:MAP_ERR
ECHO /MAP requires: drive_letter share_path
GOTO HELP_ERR

:DEFRAG_ERR
ECHO /DEFRAG requires: drive_letter
GOTO HELP_ERR

:TCP_ERR
ECHO /TCPIP requires: host
GOTO HELP_ERR

:ALL_ERR
ECHO /ALL requires MAP_DRIVE, SHARE_PATH, DEFRAG_DRIVE, and TCP_HOST environment variables.
GOTO HELP_ERR

:HELP
ECHO.
ECHO EssentialEnterpriseThingy DOS command batcher
ECHO.
ECHO Usage:
ECHO   EET.BAT /MAP drive_letter share_path [/DEFRAG drive_letter] [/TCPIP host]
ECHO   EET.BAT /DEFRAG drive_letter
ECHO   EET.BAT /TCPIP host
ECHO   EET.BAT /ALL
ECHO.
ECHO /ALL uses:
ECHO   MAP_DRIVE, SHARE_PATH, DEFRAG_DRIVE, TCP_HOST
ECHO.
GOTO END_OK

:HELP_ERR
ECHO.
GOTO HELP

:FAIL
ECHO.
ECHO Command batch failed.
GOTO END_FAIL

:DONE
ECHO.
ECHO Command batch completed successfully.
GOTO END_OK

:END_OK
GOTO END

:END_FAIL
GOTO END

:END
